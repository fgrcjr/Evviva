---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Our Programs - Evviva Montessori">
  <main>
    <!-- Hero Section -->
    <section class="pt-32 pb-20 bg-gradient-to-b from-nature-sand to-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <span class="text-primary font-medium mb-4 block">Education</span>
            <h1 class="text-5xl font-display font-bold mb-6">
              Discover Our Enriching Programs
            </h1>
            <p class="text-xl text-gray-600 mb-8 leading-relaxed">
              Our carefully crafted programs are designed to nurture your child's natural curiosity and foster a love for learning through play-based activities and structured development.
            </p>
            <ul class="space-y-4 mb-8">
              <li class="flex items-center gap-3">
                <span class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center">
                  <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <span class="text-gray-700">Age-appropriate curriculum for each development stage.</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center">
                  <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <span class="text-gray-700">Hands-on learning experiences and creative activities.</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center">
                  <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <span class="text-gray-700">Regular progress updates and parent communication.</span>
              </li>
            </ul>
            <div class="flex gap-4">
              <a href="/programs" class="inline-block px-8 py-3 border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors rounded-full">
                Learn More
              </a>
              <a href="/contact-us" class="inline-block px-8 py-3 bg-primary text-white hover:bg-primary-dark transition-colors rounded-full">
                Enroll Now
              </a>
            </div>
          </div>
          <div class="relative">
            <div class="absolute inset-0 bg-primary/10 rounded-[2.5rem] rotate-6 transform hover:rotate-0 transition-transform duration-500"></div>
            <img 
              src="/programs-hero.jpg" 
              alt="Children engaged in creative learning activities" 
              class="rounded-[2.5rem] shadow-xl relative z-10 transform hover:scale-105 transition-all duration-500 object-cover w-full aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Programs Overview Section -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-display font-bold mb-4">Our Curriculum</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            We offer comprehensive programs tailored to different age groups, ensuring optimal development at every stage.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div class="bg-white p-8 rounded-[2rem] shadow-lg hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-display font-bold mb-4">Infant Care (6 weeks - 12 months)</h3>
            <ul class="space-y-3 text-gray-600">
              <li>• Nurturing, safe environment</li>
              <li>• Sensory development activities</li>
              <li>• Motor skills development</li>
              <li>• Individual care routines</li>
            </ul>
          </div>
          
          <div class="bg-white p-8 rounded-[2rem] shadow-lg hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-display font-bold mb-4">Toddler Program (1-2 years)</h3>
            <ul class="space-y-3 text-gray-600">
              <li>• Language development</li>
              <li>• Social interaction</li>
              <li>• Creative expression</li>
              <li>• Physical activities</li>
            </ul>
          </div>
          
          <div class="bg-white p-8 rounded-[2rem] shadow-lg hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <h3 class="text-2xl font-display font-bold mb-4">Preschool (3-5 years)</h3>
            <ul class="space-y-3 text-gray-600">
              <li>• Early mathematics</li>
              <li>• Reading readiness</li>
              <li>• Science exploration</li>
              <li>• Art and music</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>