---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Evviva Montessori - Guiding Young Minds">
  <main>
    <!-- Hero Section -->
    <section class="pt-32 pb-20 bg-gradient-to-b from-nature-sand to-white relative overflow-hidden">
      <div class="absolute inset-0 bg-leaf-pattern opacity-5"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="relative z-10">
            <div class="absolute -left-4 -top-4 w-20 h-20 bg-secondary/20 rounded-full blur-xl"></div>
            <div class="absolute -right-8 bottom-4 w-32 h-32 bg-primary/20 rounded-full blur-xl"></div>
            <h1 class="font-display text-6xl font-bold text-gray-900 mb-6 leading-tight">
              Nurturing <span class="text-primary">Minds</span>, Growing <span class="text-primary">Hearts</span>
            </h1>
            <p class="text-xl text-gray-600 mb-8 leading-relaxed">
              Join our vibrant community where every child's curiosity is celebrated and nurtured through engaging, hands-on learning experiences.
            </p>
            <div class="space-x-4">
              <a href="/contact-us" class="inline-block bg-primary text-white px-8 py-4 rounded-full hover:bg-primary-dark transition-all transform hover:scale-105 shadow-lg hover:shadow-xl">
                Enroll Now
              </a>
              <a href="/programs" class="inline-block border-2 border-primary text-primary px-8 py-4 rounded-full hover:bg-primary hover:text-white transition-all transform hover:scale-105">
                Our Programs
              </a>
            </div>
          </div>
          <div class="relative">
            <div class="absolute inset-0 bg-primary/10 rounded-[2.5rem] rotate-6 transform hover:rotate-0 transition-transform duration-500"></div>
            <img 
              src="/teacher-with-children.jpg" 
              alt="Teacher reading to children in a nurturing environment" 
              class="rounded-[2.5rem] shadow-xl relative z-10 transform hover:scale-105 transition-all duration-500 object-cover h-[600px] w-full"
            />
            <div class="absolute -bottom-6 -right-6 bg-white p-6 rounded-2xl shadow-xl z-20 transform hover:scale-110 transition-transform">
              <p class="font-display font-bold text-primary text-lg">Experienced Educators</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-24 bg-nature-sand/30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-display font-bold mb-4">Why Choose Evviva?</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            We provide a nurturing environment where children can learn, grow, and thrive through play-based learning and structured activities.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div class="bg-white p-8 rounded-[2rem] shadow-lg hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <h3 class="text-2xl font-display font-bold mb-4">Montessori Curriculum</h3>
            <p class="text-gray-600">
              Our curriculum is designed to foster independence, creativity, and a love for learning in every child.
            </p>
          </div>
          
          <div class="bg-white p-8 rounded-[2rem] shadow-lg hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-display font-bold mb-4">Expert Teachers</h3>
            <p class="text-gray-600">
              Our experienced educators are passionate about early childhood development and creating engaging learning experiences.
            </p>
          </div>
          
          <div class="bg-white p-8 rounded-[2rem] shadow-lg hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
            </div>
            <h3 class="text-2xl font-display font-bold mb-4">Safe Environment</h3>
            <p class="text-gray-600">
              We maintain the highest standards of safety and cleanliness to provide a secure learning environment for your child.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="py-24 bg-primary/5 relative overflow-hidden">
      <div class="absolute inset-0 bg-dots-pattern opacity-5"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-display font-bold mb-4">What Parents Say</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Don't just take our word for it. Here's what our community of parents has to say about their experience with Evviva.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div class="bg-white p-8 rounded-[2rem] shadow-lg">
            <div class="flex items-center mb-6">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
                  <span class="text-xl font-bold text-primary">S</span>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="font-display font-bold">Sarah M.</h3>
                <p class="text-gray-600">Parent of Alex</p>
              </div>
            </div>
            <p class="text-gray-600">
              "The teachers at Evviva are exceptional. They've created such a nurturing environment where my child loves to learn and explore."
            </p>
          </div>
          
          <div class="bg-white p-8 rounded-[2rem] shadow-lg">
            <div class="flex items-center mb-6">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
                  <span class="text-xl font-bold text-primary">J</span>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="font-display font-bold">James R.</h3>
                <p class="text-gray-600">Parent of Emma</p>
              </div>
            </div>
            <p class="text-gray-600">
              "We've seen incredible growth in our daughter's social skills and creativity since she started at Evviva. It's been amazing!"
            </p>
          </div>
          
          <div class="bg-white p-8 rounded-[2rem] shadow-lg">
            <div class="flex items-center mb-6">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
                  <span class="text-xl font-bold text-primary">M</span>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="font-display font-bold">Maria L.</h3>
                <p class="text-gray-600">Parent of Lucas</p>
              </div>
            </div>
            <p class="text-gray-600">
              "The curriculum is well-structured and engaging. My son has developed a real love for learning thanks to the wonderful staff."
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>